{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && npm run sentry:sourcemaps",
    "start": "node --import ./instrument.mjs dist/index.js",
    "ingest:once": "RUN_ONCE=true tsx src/index.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org na-5vj --project node-fastify ./dist && sentry-cli sourcemaps upload --org na-5vj --project node-fastify ./dist"
  },
  "devDependencies": {
    "drizzle-kit": "^1.0.0-rc.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@sentry/cli": "^2.58.6",
    "@sentry/node": "^10.63.0",
    "@sentry/profiling-node": "^10.63.0",
    "@types/node": "^26.0.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-rc.4",
    "fastify": "^5.9.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}